// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. NEXTAUTH JS SCHEMA (WAJIB UNTUK GOOGLE LOGIN)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Relasi ke tabel spesifik aplikasi kita
  profile       Profile?
  histories     AnalysisHistory[]
  reviews       ProductReview[] 
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. SKINCARE APP SCHEMA (ARSITEKTUR V3)
// ==========================================

enum SeverityLevel {
  BIASA
  SEDANG
  PARAH
}

enum ProductType {
  FACEWASH
  MOISTURIZER
  SUNSCREEN
}

enum IngredientType {
  TOXIC    
  HARSH    
  BUFFER   
  BASIC    
}

enum FunctionalCategory {
  SURFAKTAN
  UV_FILTER
  PELEMBAP_HUMEKTAN  
  PELEMBAP_EMOLIEN   
  PELEMBAP_OKLUSIF   
  UMUM
}

// ==========================================
// 3. ADMIN ROLE-BASED ACCESS CONTROL (RBAC)
// ==========================================

enum AdminRole {
  SUPERADMIN
  ADMIN
  VIEWER
}

model AdminAccount {
  id          String    @id @default(cuid())
  username    String    @unique
  password    String    
  role        AdminRole @default(VIEWER)
  permissions String[]  // Menyimpan daftar akses: MANAGE_KAMUS, MANAGE_TINJAUAN, dll
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==========================================
// 4. MAIN DATA MODELS
// ==========================================

model Profile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  skinType            String        
  age                 Int
  severity            SeverityLevel
  
  primaryFocus        String        
  
  allergies           String?       
  isPregnantOrNursing Boolean       @default(false) 

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model AnalysisHistory {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productName      String?     
  productType      ProductType
  ingredientsInput String      @db.Text 
  
  matchScore       Int         
  safetyScore      Int         
  aiResponse       Json        
  
  isSaved          Boolean     @default(false) 

  createdAt        DateTime    @default(now())
}

model IngredientDictionary {
  id                   String             @id @default(cuid())
  name                 String             @unique 
  type                 IngredientType     @default(BASIC) 
  functionalCategory   FunctionalCategory @default(UMUM) 
  
  benefits             String             @db.Text 
  warnings             String?            @db.Text 
  comedogenicRating    Int                @default(0) 
  aliases              String?            
  
  safeForPregnancy     Boolean            @default(true) 
  safeForSensitive     Boolean            @default(true) 
  
  isKeyActive          Boolean            @default(false)
  strengthLevel        Int                @default(1)
  blacklistedSkinTypes String?            @db.Text
  blacklistReason      String?            @db.Text
  isVerified           Boolean            @default(false) 
  aiContext            String?            @db.Text 
  
  goodForSkinTypes     String?        
  targetFocus          String?        

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model UnknownIngredient {
  id          String   @id @default(cuid())
  name        String   @unique 
  reportCount Int      @default(1) 
  isReviewed  Boolean  @default(false) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IngredientReport {
  id             String   @id @default(cuid())
  ingredientName String   
  reason         String   @db.Text 
  isReviewed     Boolean  @default(false)
  
  createdAt      DateTime @default(now())
}

model ProductCatalog {
  id              String          @id @default(cuid())
  namaProduk      String
  tipeProduk      ProductType
  gambarUrl       String          @db.Text
  tautanAfiliasi  String          @db.Text
  komposisiAsli   String          @db.Text
  fokusProduk     String          
  isPinKreator    Boolean         @default(false)
  masalahKulitPin String?         
  catatanKreator  String?         @db.Text 

  reviews         ProductReview[] 

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ProductReview {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     ProductCatalog @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  rating      Int            
  komentar    String         @db.Text 

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}