// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. NEXTAUTH JS SCHEMA (WAJIB UNTUK GOOGLE LOGIN)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Relasi ke tabel spesifik aplikasi kita
  profile       Profile?
  histories     AnalysisHistory[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. SKINCARE APP SCHEMA
// ==========================================

enum SeverityLevel {
  BIASA
  SEDANG
  PARAH
}

enum SkinFocus {
  MENCERAHKAN
  MENURUNKAN_JERAWAT
  MERAWAT_MEMBERSIHKAN
  MENGHILANGKAN_BEKAS
}

enum ProductType {
  FACEWASH
  MOISTURIZER
  SUNSCREEN
}

// TIPE BAHAN UNTUK LOGIKA MATEMATIKA AI
enum IngredientType {
  HERO     // Bahan utama yang sangat bagus (Bisa nambah skor)
  TOXIC    // Bahan dilarang/berbahaya mutlak (Skor langsung 0)
  HARSH    // Bahan keras/aktif yang butuh penenang (Bisa ngurangin skor)
  BUFFER   // Bahan penenang/pelembap penyeimbang HARSH
  BASIC    // Bahan standar (Pelarut, pengawet aman, tekstur)
}

// KATEGORI FUNGSIONAL KHUSUS (BARU)
enum FunctionalCategory {
  SURFAKTAN
  UV_FILTER
  PELEMBAP
  UMUM
}

model Profile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  skinType            String        // Contoh: Kering, Berminyak, Kombinasi, Normal (bisa gabung Sensitif)
  age                 Int
  severity            SeverityLevel
  primaryFocus        SkinFocus
  allergies           String?       // Disimpan sebagai string yang dipisahkan koma
  isPregnantOrNursing Boolean       @default(false) 

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model AnalysisHistory {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productName      String?     
  productType      ProductType
  ingredientsInput String      @db.Text 
  
  matchScore       Int         // 0-100
  safetyScore      Int         // 0-100
  aiResponse       Json        // Menyimpan Penjelasan AI & Rekomendasi
  
  isSaved          Boolean     @default(false) 

  createdAt        DateTime    @default(now())
}

// ==========================================
// 3. INGREDIENT DICTIONARY & UNKNOWN INGREDIENTS
// ==========================================

model IngredientDictionary {
  id                 String             @id @default(cuid())
  name               String             @unique // Nama bahan (huruf kecil semua)
  type               IngredientType     @default(BASIC) // Kategori logika bahan
  functionalCategory FunctionalCategory @default(UMUM) // Kategori Fungsional (BARU)
  
  benefits           String             @db.Text // Penjelasan manfaat
  warnings           String?            @db.Text // Peringatan khusus
  comedogenicRating  Int                @default(0) // Skala 0-5
  aliases            String?            // Untuk menampung sinonim beda bahasa, dipisah koma
  
  // Keamanan Khusus
  safeForPregnancy   Boolean            @default(true) // Aman untuk bumil/menyusui?
  safeForSensitive   Boolean            @default(true) // Aman untuk kulit sensitif?
  
  // Kecocokan Kulit (Format string dipisah koma, contoh: "Kering,Normal")
  goodForSkinTypes   String?        
  badForSkinTypes    String?        
  
  // Fokus Perawatan (Jika ini tipe HERO, cocok untuk apa? misal: "MENCERAHKAN")
  targetFocus        String?        

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

// Menangkap bahan asing hasil input user yang belum ada di Database
model UnknownIngredient {
  id          String   @id @default(cuid())
  name        String   @unique // Nama bahan yang tidak dikenali (huruf kecil)
  reportCount Int      @default(1) // Berapa kali bahan ini diinput user
  isReviewed  Boolean  @default(false) // Apakah sudah dicek oleh Admin?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}