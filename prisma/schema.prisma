// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. NEXTAUTH JS SCHEMA (WAJIB UNTUK GOOGLE LOGIN)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Relasi ke tabel spesifik aplikasi kita
  profile       Profile?
  histories     AnalysisHistory[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. SKINCARE APP SCHEMA (ARSITEKTUR V3)
// ==========================================

enum SeverityLevel {
  BIASA
  SEDANG
  PARAH
}

enum ProductType {
  FACEWASH
  MOISTURIZER
  SUNSCREEN
}

// TIPE BAHAN UNTUK LOGIKA MATEMATIKA AI
enum IngredientType {
  TOXIC    // Bahan dilarang/berbahaya mutlak
  HARSH    // Bahan keras/aktif yang butuh penenang
  BUFFER   // Bahan penenang/pereda inflamasi
  BASIC    // Bahan standar (Pelarut, pengawet aman, tekstur)
}

// KATEGORI FUNGSIONAL KHUSUS
enum FunctionalCategory {
  SURFAKTAN
  UV_FILTER
  PELEMBAP_HUMEKTAN  // Berbasis air (ringan)
  PELEMBAP_EMOLIEN   // Berbasis lemak (menengah)
  PELEMBAP_OKLUSIF   // Berbasis minyak/lilin (tebal)
  UMUM
}

model Profile {
  id                  String        @id @default(cuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  skinType            String        // Contoh: Kering, Berminyak, Kombinasi, Normal (bisa gabung Sensitif)
  age                 Int
  severity            SeverityLevel
  
  // Diubah menjadi String biasa agar bisa menyimpan banyak teks yang dipisah koma
  primaryFocus        String        
  
  allergies           String?       // Disimpan sebagai string yang dipisahkan koma
  isPregnantOrNursing Boolean       @default(false) 

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model AnalysisHistory {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productName      String?     
  productType      ProductType
  ingredientsInput String      @db.Text 
  
  matchScore       Int         // 0-100
  safetyScore      Int         // 0-100
  aiResponse       Json        // Menyimpan Penjelasan AI & Rekomendasi
  
  isSaved          Boolean     @default(false) 

  createdAt        DateTime    @default(now())
}

// ==========================================
// 3. INGREDIENT DICTIONARY & UNKNOWN INGREDIENTS
// ==========================================

model IngredientDictionary {
  id                   String             @id @default(cuid())
  name                 String             @unique // Nama bahan (huruf kecil semua)
  type                 IngredientType     @default(BASIC) 
  functionalCategory   FunctionalCategory @default(UMUM) 
  
  benefits             String             @db.Text 
  warnings             String?            @db.Text 
  comedogenicRating    Int                @default(0) // Skala 0-5
  aliases              String?            // Sinonim beda bahasa, dipisah koma
  
  // Keamanan Khusus
  safeForPregnancy     Boolean            @default(true) 
  safeForSensitive     Boolean            @default(true) 
  
  // --- FITUR BARU V3 ---
  isKeyActive          Boolean            @default(false)
  strengthLevel        Int                @default(1)
  blacklistedSkinTypes String?            @db.Text
  blacklistReason      String?            @db.Text
  // ---------------------
  
  goodForSkinTypes     String?        
  targetFocus          String?        

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

// Menangkap bahan asing hasil input user yang belum ada di Database
model UnknownIngredient {
  id          String   @id @default(cuid())
  name        String   @unique // Nama bahan yang tidak dikenali
  reportCount Int      @default(1) 
  isReviewed  Boolean  @default(false) 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}